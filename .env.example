# ═══════════════════════════════════════════════════════════════════════════════
# Chinese Drama Dubber — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ─────────────────────────────────────────────────────────────────────────────
# LLM API (Groq) — https://console.groq.com/keys
# ─────────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# Fish Speech (Local TTS) — Optional, for premium quality
# Install: https://github.com/fishaudio/fish-speech
# Run: python -m fish_audio.main --listen localhost:8080
# ─────────────────────────────────────────────────────────────────────────────
FISH_SPEECH_URL=http://localhost:8080

# ─────────────────────────────────────────────────────────────────────────────
# YouTube Cookies (Optional — for age-restricted/bot-protected videos)
# Install "Get cookies.txt LOCALLY" browser extension, export cookies
# ─────────────────────────────────────────────────────────────────────────────
COOKIE_FILE=

# ─────────────────────────────────────────────────────────────────────────────
# Output Settings
# ─────────────────────────────────────────────────────────────────────────────
OUTPUT_DIR=/content/drive/MyDrive/DubbedVideos

# ─────────────────────────────────────────────────────────────────────────────
# Performance Settings
# ─────────────────────────────────────────────────────────────────────────────
TTS_WORKERS=5              # Parallel TTS workers (adjust based on GPU/CPU)
LLM_TIMEOUT=60              # Timeout for LLM API calls in seconds
MAX_RETRIES=4              # Max retries for failed API calls
